// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentProvider {
  WAVE
  ORANGE_MONEY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// --- CATALOGUE PRODUITS ---

enum ProductCategory {
  INTERNET
  STARLINK
  TELEPHONIE
  EQUIPEMENT  // Matériel réseau (routeurs, CPE, AP, ONU, radios…)
  AUTRE
}

model Product {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String          @unique
  shortDescription String?
  description      String?         @db.Text
  category         ProductCategory
  priceXof         Int?            // Prix en XOF — null = "sur devis"
  priceUnit        String?         // "mois" | "an" | "unique"
  speed            String?         // Ex : "20 Mbps", "50 Mbps"
  features         String[]        // Liste des avantages/caractéristiques
  imageUrl         String?         // URL relative de l'image produit (ex : /products/image4.png)
  highlighted      Boolean         @default(false) // Badge "Populaire"
  published        Boolean         @default(false) // Visible sur le site public
  position         Int             @default(0)     // Ordre d'affichage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([position])
}

// --- NOUVEAU : ENTITÉ CLIENT ---

model Client {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Identité
  phone     String  @unique @db.VarChar(20) // Identifiant métier principal (Mobile Money)
  firstName String?
  lastName  String?
  email     String? @unique
  villageId   String  @db.Uuid
  village Village   @relation(fields: [villageId], references: [id], onDelete: Restrict)

  // Relations
  payments Payment[] // Un client peut avoir plusieurs paiements

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

model Village {
  id String @id @default(dbgenerated("gen_random_uuid()"))  @db.Uuid
  titre String  @unique()

  // Relations
  clients Client[]

  @@index([titre])
}

// --- ENTITÉ PAIEMENT (Mise à jour) ---

model Payment {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount   Int
  currency String @default("XOF") @db.VarChar(3)

  provider PaymentProvider
  status   PaymentStatus   @default(PENDING)

  // --- RELATION CLIENT ---
  clientId String @db.Uuid
  // RESTRICT : Interdit la suppression d'un client s'il a des paiements (Règle d'audit financier)
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  internalRef String  @unique @default(cuid())
  providerRef String? @unique

  metadata     Json?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([internalRef])
  @@index([clientId]) // Nouvel index pour filtrer rapidement les paiements d'un client
}
